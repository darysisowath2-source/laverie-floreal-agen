          <path d="M40 0 C38 50 32 95 44 145 C56 195 48 230 40 260" stroke="#3d5a2a" stroke-width="1.5" stroke-linecap="round" opacity="0.22"/>
          <ellipse cx="22"  cy="60"  rx="12" ry="24" transform="rotate(-38 22 60)"   fill="#3d5a2a" opacity="0.18"/>
          <ellipse cx="60"  cy="42"  rx="11" ry="22" transform="rotate(35 60 42)"    fill="#3d5a2a" opacity="0.16"/>
          <ellipse cx="20"  cy="118" rx="11" ry="22" transform="rotate(-36 20 118)"  fill="#3d5a2a" opacity="0.16"/>
          <ellipse cx="62"  cy="100" rx="10" ry="20" transform="rotate(32 62 100)"   fill="#3d5a2a" opacity="0.15"/>
          <ellipse cx="22"  cy="178" rx="10" ry="20" transform="rotate(-34 22 178)"  fill="#3d5a2a" opacity="0.15"/>
          <!-- Petite fleur terracotta en haut -->
          <g opacity="0.20">
            <ellipse cx="40" cy="4"  rx="5" ry="11" fill="#b5673a"/>
            <ellipse cx="40" cy="4"  rx="5" ry="11" transform="rotate(60 40 14)"  fill="#b5673a"/>
            <ellipse cx="40" cy="4"  rx="5" ry="11" transform="rotate(120 40 14)" fill="#b5673a"/>
            <ellipse cx="40" cy="4"  rx="5" ry="11" transform="rotate(180 40 14)" fill="#b5673a"/>
            <ellipse cx="40" cy="4"  rx="5" ry="11" transform="rotate(240 40 14)" fill="#b5673a"/>
            <ellipse cx="40" cy="4"  rx="5" ry="11" transform="rotate(300 40 14)" fill="#b5673a"/>
            <circle  cx="40" cy="14" r="4" fill="#b5673a"/>
          </g>
        </svg>
      </div>

      <div class="relative max-w-[1240px] mx-auto px-5 sm:px-8 py-20 sm:py-28 grid lg:grid-cols-12 gap-10 reveal-on-scroll">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-3">Avant de venir</p>
          <h2 class="font-medium tracking-tight" style="font-size: var(--text-h2);">
            Questions <em class="font-display italic font-light" style="color: var(--color-muted-strong);">fréquentes.</em>
          </h2>
        </div>
        <div class="lg:col-span-8">
          <ul class="border-y divide-y" style="border-color: var(--color-line);">
            {faq.map((item) => (
              <li>
                <details>
                  <summary class="py-5 sm:py-6 flex items-center justify-between gap-6 cursor-pointer">
                    <span class="text-base sm:text-lg font-medium pr-4">{item.q}</span>
                    <span class="faq-toggle text-3xl font-light shrink-0" style="color: var(--color-muted);">+</span>
                  </summary>
                  <p class="faq-answer pb-6 pr-12 leading-relaxed" style="color: var(--color-muted-strong);">{item.a}</p>
                </details>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════
         CONTACT — fleur immense derrière, transparente
    ═══════════════════════════════════════════════════════════════ -->
    <section id="contact" class="relative overflow-hidden" style="background: transparent;">

      <!-- Immense fleur centrale, mix-blend, dérive infime -->

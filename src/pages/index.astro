            <ellipse cx="350" cy="80"  rx="30" ry="80" transform="rotate(200 350 350)" fill="#3d5a2a"/>
            <ellipse cx="350" cy="80"  rx="30" ry="80" transform="rotate(220 350 350)" fill="#3d5a2a"/>
            <ellipse cx="350" cy="80"  rx="30" ry="80" transform="rotate(240 350 350)" fill="#3d5a2a"/>
            <ellipse cx="350" cy="80"  rx="30" ry="80" transform="rotate(260 350 350)" fill="#3d5a2a"/>
            <ellipse cx="350" cy="80"  rx="30" ry="80" transform="rotate(280 350 350)" fill="#3d5a2a"/>
            <ellipse cx="350" cy="80"  rx="30" ry="80" transform="rotate(300 350 350)" fill="#3d5a2a"/>
            <ellipse cx="350" cy="80"  rx="30" ry="80" transform="rotate(320 350 350)" fill="#3d5a2a"/>
            <ellipse cx="350" cy="80"  rx="30" ry="80" transform="rotate(340 350 350)" fill="#3d5a2a"/>
            <circle  cx="350" cy="350" r="52"           fill="#b5673a"/>
          </g>
        </svg>
      </div>

      <div class="relative max-w-[1240px] mx-auto px-5 sm:px-8 py-24 sm:py-32 text-center reveal-on-scroll">
        <p class="eyebrow mb-6">Contact</p>
        <h2 class="font-medium tracking-tight max-w-2xl mx-auto leading-[1.05]" style="font-size: var(--text-display);">
          Une question ?<br/>
          <em class="font-display italic font-light" style="color: var(--color-muted-strong);">On répond vite.</em>
        </h2>
        <div class="mt-12 flex flex-wrap items-center justify-center gap-3">
          <a href="tel:0768740073" class="cta">07 68 74 00 73 <span aria-hidden="true">→</span></a>
          <a href="mailto:laveriedufloreal@gmail.com" class="cta-ghost">laveriedufloreal@gmail.com</a>
